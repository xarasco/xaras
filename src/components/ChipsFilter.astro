---
import { KIND_TAGS, LENS_TAGS } from '@/lib/classify';

interface Counts {
  total: number;
  byKind: Record<string, number>;
  byLens: Record<string, number>;
}

interface Props {
  counts: Counts;
  activeKind?: string;
  activeLens?: string | null;
}

const { counts, activeKind = 'all', activeLens = null } = Astro.props;

const kindRow = [
  { l: 'all', n: counts.total },
  ...KIND_TAGS.map((k) => ({ l: k, n: counts.byKind[k] ?? 0 })),
];

const lensRow = LENS_TAGS.map((k) => ({ l: k, n: counts.byLens[k] ?? 0 }));
---

<div class="chip-filter">
  <div class="chip-row">
    <span class="row-label">kind</span>
    {
      kindRow.map((k) => (
        <button
          type="button"
          class="chip"
          data-row="kind"
          data-value={k.l}
          aria-pressed={k.l === activeKind ? 'true' : 'false'}
        >
          {k.l}
          <span class="count">{k.n}</span>
        </button>
      ))
    }
  </div>
  <div class="chip-row">
    <span class="row-label">lens</span>
    {
      lensRow.map((k) => (
        <button
          type="button"
          class="chip"
          data-row="lens"
          data-value={k.l}
          aria-pressed={k.l === activeLens ? 'true' : 'false'}
        >
          {k.l}
          <span class="count">{k.n}</span>
        </button>
      ))
    }
  </div>
</div>

<script>
  const root = document.querySelector<HTMLElement>('.chip-filter');
  const entries = document.querySelectorAll<HTMLElement>('.entries .entry');
  if (root && entries.length) {
    const state: { kind: string; lens: string | null } = { kind: 'all', lens: null };

    const apply = () => {
      entries.forEach((el) => {
        const k = el.dataset.kind ?? '';
        const lenses = (el.dataset.lenses ?? '').split(' ').filter(Boolean);
        const kindOk = state.kind === 'all' || k === state.kind;
        const lensOk = !state.lens || lenses.includes(state.lens);
        el.hidden = !(kindOk && lensOk);
      });
    };

    const setPressed = (row: 'kind' | 'lens', active: HTMLElement | null) => {
      root.querySelectorAll<HTMLElement>(`.chip[data-row="${row}"]`).forEach((c) => {
        c.setAttribute('aria-pressed', c === active ? 'true' : 'false');
      });
    };

    root.querySelectorAll<HTMLElement>('.chip').forEach((chip) => {
      chip.addEventListener('click', () => {
        const row = chip.dataset.row as 'kind' | 'lens' | undefined;
        const value = chip.dataset.value ?? '';
        if (row === 'kind') {
          state.kind = value;
          setPressed('kind', chip);
        } else if (row === 'lens') {
          if (state.lens === value) {
            state.lens = null;
            setPressed('lens', null);
          } else {
            state.lens = value;
            setPressed('lens', chip);
          }
        }
        apply();
      });
    });
  }
</script>
